# --- Dynamic Theme ---
# This file is a symlink
include=~/.config/mako/theme_current

## --- Mako Configuration ---
max-history=100
sort=-time
default-timeout=8000

# --- Structural Style (Minimal & Sharp) ---
font=monospace 10
width=300
height=110
margin=15
padding=12
border-size=2
border-radius=0
icons=1
max-icon-size=32

# --- Icons ---
icon-path=/usr/share/icons/hicolor

[urgency=high]
border-color=#eb6f92
default-timeout=0

[urgency=low]
border-color=#908caa
default-timeout=5000


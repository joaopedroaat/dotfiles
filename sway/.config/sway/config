# ==========================================
# Sway Window Manager Configuration
# ==========================================

### Core Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term kitty
set $menu wmenu-run

set $script_dir ~/.config/sway/scripts/
set $status_command $script_dir/status
set $lock_command $script_dir/lock

# Theme bootstrapping
exec_always [ ! -e ~/.config/sway/themes/sway_current.conf ] && ln -s ~/.config/sway/themes/sway_dark.conf ~/.config/sway/themes/sway_current.conf
include ~/.config/sway/themes/sway_current.conf

# Systemd and dbus activation environments
exec systemctl --user import-environment WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP SWAYSOCK I3SOCK XCURSOR_SIZE XCURSOR_THEME
exec dbus-update-activation-environment WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP SWAYSOCK I3SOCK XCURSOR_SIZE XCURSOR_THEME

# Autostart applications
exec pkill mako; mako
exec pkill mpd-mpris; mpd-mpris
exec $term --class=QuickTerm

### Output & Input Configuration
input type:keyboard {
    xkb_layout "br"
}

# Display and wallpaper
exec_always "swaybg-mngr || swaymsg 'output * bg /usr/share/backgrounds/sway/Sway_Wallpaper_Blue_1920x1080.png fill'"

### UI & Appearance
# Typography
set $gui_font pango:JetBrainsMono Nerd Font 10
font $gui_font

# Borders and Gaps
default_border pixel 1
default_floating_border pixel 2
gaps inner 5
gaps outer 2
smart_gaps on
smart_borders on

# Layer Differentiators
# Thicker borders and slight transparency for all windows to help floating windows pop
for_window [floating] border pixel 2
for_window [tiling] border pixel 1
for_window [app_id=".*"] opacity 0.98

# Window Decorations
# target                 border   bg       text    indicator child_border
client.focused           $iris    $base    $text   $rose     $iris
client.focused_inactive  $muted   $surface $subtle $muted    $muted
client.unfocused         $muted   $base    $muted  $overlay  $muted
client.urgent            $love    $base    $text   $gold     $love

### Status Bar
bar {
    position top
    font $gui_font
    status_command "$status_command || while date +'%d-%m-%Y %H:%M:%S'; do sleep 1; done"
    pango_markup enabled

    tray_padding 2

    colors {
        background         $overlay
        statusline         $text
        separator          $iris

        #                  border    bg        text
        focused_workspace  $iris     $iris     $base
        active_workspace   $surface  $surface  $text
        inactive_workspace $overlay  $overlay  $muted
    }
}

### Window Rules & Behavior
# Focus settings
focus_on_window_activation focus
focus_follows_mouse yes

# Specific window rules

# Quick Terminal
for_window [app_id="QuickTerm"] {
    floating enable
    border pixel 2
    resize set 800 600
    move position center
    move scratchpad
    scratchpad show
}

for_window [app_id="AudioControl"] {
    floating enable
    border pixel 2
    resize set 800 600
    move position center
}

for_window [app_id="RMPC"] {
    floating enable
    border pixel 2
    resize set 1250 750
    move position center
    move scratchpad
    scratchpad show
}

for_window [app_id="FileExplorer"] {
    floating enable
    border pixel 2
    resize set 1250 750
    move position center
    move scratchpad
    scratchpad show
}

for_window [app_id="TaskManager"] {
    floating enable
    border pixel 2
    resize set 1250 750
    move position center
    move scratchpad
    scratchpad show
}

for_window [app_id="popup"] {
    floating enable
    border pixel 2
    resize set 1250 750
    move position center
}

# ==========================================
# Key Bindings
# ==========================================

### Core Applications & Controls
bindsym $mod+Return exec $term
bindsym $mod+d exec $menu
bindsym $mod+Shift+q kill
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit sway and end Wayland session?' -B 'Yes, exit' 'swaymsg exit'
bindsym $mod+Escape exec "$lock_command || swaylock -c '$base'"

### Notifications & Utilities
bindsym $mod+Shift+n exec makoctl dismiss
bindsym $mod+Control+n exec makoctl restore
bindsym $mod+t exec darkman toggle
bindsym Control+Mod1+t exec $term --class=QuickTerm
bindsym Control+Mod1+p exec $term --class=AudioControl -e pulsemixer
bindsym Control+Mod1+e exec $term --class=FileExplorer -e yazi
bindsym Control+Mod1+m exec $term --class=RMPC -e rmpc
bindsym Control+Mod1+Delete exec $term --class=TaskManager -e btop

### Screenshots
# 1. Full Screen
# Print = Save to file
bindsym Print exec grim
# Shift + Print = Copy to clipboard
bindsym Shift+Print exec grim - | wl-copy

# 2. Select Region or Window
# Mod + Print = Save selected area to file
bindsym $mod+Print exec grim -g "$(slurp)"
# Mod + Shift + Print = Copy selected area to clipboard
bindsym $mod+Shift+Print exec grim -g "$(slurp)" - | wl-copy

### Media & Hardware Keys
bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+

### Focus Management
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+a focus parent

### Window Movement
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Mod + Left Click to drag, Mod + Right Click to resize
floating_modifier $mod normal

### Layout & Modes
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

### Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

### Scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

### Resizing Mode
mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"
